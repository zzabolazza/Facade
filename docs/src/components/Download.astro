---
const platforms = [
  {
    name: 'Windows',
    eyebrow: 'RECOMMENDED',
    note: '安装程序与便携包',
    file: 'Facade-Setup-1.3.6.exe',
    meta: 'Windows 10 / 11 · x64 / arm64',
    primary: true,
    icon: `<path d="M3 5.5 11 4v7H3V5.5Zm9-1.7L21 2v9h-9V3.8ZM3 12h8v7l-8-1.5V12Zm9 0h9v9l-9-1.7V12Z"/>`,
  },
  {
    name: 'macOS',
    eyebrow: 'APPLE SILICON + INTEL',
    note: '应用程序压缩包',
    file: 'Facade-1.3.6-macos.zip',
    meta: 'macOS · arm64 / amd64',
    icon: `<path d="M16.7 12.9c0-2.2 1.8-3.3 1.9-3.4a4 4 0 0 0-3.2-1.7c-1.4-.1-2.7.8-3.4.8-.7 0-1.8-.8-3-.8-1.5 0-3 .9-3.8 2.3-1.7 2.9-.4 7.3 1.2 9.7.8 1.2 1.8 2.5 3 2.4 1.2 0 1.7-.8 3.3-.8 1.5 0 2 .8 3.3.8 1.4 0 2.2-1.2 3-2.4.9-1.3 1.3-2.6 1.3-2.7-.1 0-3.6-1.4-3.6-4.2ZM14.5 6.4A4 4 0 0 0 15.4 3a4 4 0 0 0-2.7 1.4 3.7 3.7 0 0 0-.9 2.8c1 .1 2-.4 2.7-.8Z"/>`,
  },
  {
    name: 'Linux',
    eyebrow: 'DEB + PORTABLE',
    note: 'Debian 包与便携包',
    file: 'facade_1.3.6_amd64.deb',
    meta: 'Ubuntu / Debian · amd64 / arm64',
    icon: `<path d="M12 2.5c-3 0-5 2.4-5 5.6 0 1-.2 1.8-.7 2.7-.7 1.1-1.7 2.6-1.3 4.3.3 1.2 1.3 1.8 2.3 1.8.3 2 2 3.6 4.1 3.6h1.2c2.1 0 3.8-1.6 4.1-3.6 1 0 2-.6 2.3-1.8.4-1.7-.6-3.2-1.3-4.3-.5-.9-.7-1.7-.7-2.7 0-3.2-2-5.6-5-5.6Z"/><circle cx="10" cy="8" r=".7" fill="currentColor" stroke="none"/><circle cx="14" cy="8" r=".7" fill="currentColor" stroke="none"/><path d="M10 11.5c.7.5 1.3.7 2 .7s1.3-.2 2-.7M8.5 16.5c2.3.7 4.7.7 7 0"/>`,
  },
]

const releaseUrl = 'https://github.com/zzabolazza/Facade/releases/tag/v1.3.6'
---

<section id="download" class="relative flex min-h-[calc(100svh-5rem)] scroll-mt-20 items-center overflow-hidden border-t border-white/[0.06] py-8">
  <div class="pointer-events-none absolute inset-x-0 bottom-0 mx-auto h-[520px] max-w-5xl rounded-full bg-gradient-to-r from-indigo-600/10 via-blue-500/5 to-cyan-400/10 blur-[100px]"></div>
  <div class="relative mx-auto w-full max-w-7xl px-6">
    <div class="mb-12 flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
      <div>
        <h2 class="text-3xl font-bold tracking-[-0.035em] text-white sm:text-5xl">选择你的平台</h2>
        <p class="mt-4 max-w-xl text-sm leading-7 text-muted sm:text-base">所有版本均通过 GitHub Releases 分发。下载后即可在本地创建隔离浏览器环境。</p>
      </div>
      <a href={releaseUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-sm font-medium text-indigo-300 transition hover:text-indigo-200">
        查看全部发布文件
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14m-5-5 5 5-5 5" /></svg>
      </a>
    </div>

    <div class="grid gap-4 lg:grid-cols-3">
      {platforms.map((platform) => (
        <a
          href={releaseUrl}
          target="_blank"
          rel="noopener noreferrer"
          class:list={[
            'group relative flex min-h-[290px] flex-col overflow-hidden rounded-2xl border p-6 transition duration-300 hover:-translate-y-1 sm:p-7',
            platform.primary
              ? 'border-indigo-400/25 bg-gradient-to-br from-indigo-500/[0.13] via-[#101522] to-[#0c111c] shadow-[0_20px_60px_rgba(79,70,229,.10)]'
              : 'border-white/[0.08] bg-[#0e1320] hover:border-white/[0.16]',
          ]}
        >
          <div class="flex items-start justify-between">
            <span class:list={['flex h-12 w-12 items-center justify-center rounded-2xl', platform.primary ? 'bg-indigo-400 text-white' : 'bg-white/[0.055] text-[#b4bdd3]']}>
              <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" set:html={platform.icon} />
            </span>
            <span class:list={['text-[9px] font-semibold tracking-[0.14em]', platform.primary ? 'text-indigo-300' : 'text-[#68738b]']}>{platform.eyebrow}</span>
          </div>

          <div class="mt-8">
            <h3 class="text-xl font-semibold text-white">{platform.name}</h3>
            <p class="mt-1.5 text-sm text-muted">{platform.note}</p>
          </div>
          <div class="mt-7 rounded-xl border border-white/[0.07] bg-black/15 px-3.5 py-3">
            <p class="truncate font-mono text-[10px] text-[#c1c9dc]">{platform.file}</p>
            <p class="mt-1.5 text-[10px] text-[#626d84]">{platform.meta}</p>
          </div>

          <div class:list={['mt-auto flex items-center justify-between pt-6 text-sm font-semibold', platform.primary ? 'text-indigo-200' : 'text-[#aab4ca]']}>
            <span>前往下载</span>
            <span class:list={['flex h-8 w-8 items-center justify-center rounded-lg transition group-hover:translate-x-1', platform.primary ? 'bg-indigo-400/20' : 'bg-white/[0.05]']}>
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14m-5-5 5 5-5 5" /></svg>
            </span>
          </div>
        </a>
      ))}
    </div>

  </div>
</section>
