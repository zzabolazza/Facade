---
const features = [
  {
    label: 'ISOLATION',
    title: '实例隔离',
    desc: 'Cookie、LocalStorage、IndexedDB 与缓存各自独立，让多个账号在同一设备上稳定共存。',
    icon: `<rect x="4" y="4" width="16" height="16" rx="3"/><path d="M4 9h16M9 9v11"/>`,
    accent: 'from-indigo-500/20 to-violet-500/5 text-indigo-300',
    wide: true,
  },
  {
    label: 'NETWORK',
    title: '代理绑定',
    desc: '支持 direct、HTTP、HTTPS 与 SOCKS5，按实例分配独立出口并快速检测可用性。',
    icon: `<circle cx="12" cy="12" r="9"/><path d="M3 12h18M12 3a15 15 0 0 1 0 18M12 3a15 15 0 0 0 0 18"/>`,
    accent: 'from-cyan-500/20 to-blue-500/5 text-cyan-300',
    wide: true,
  },
  {
    label: 'KERNEL',
    title: '内核管理',
    desc: '维护多个 Chromium 版本，为不同实例选择匹配内核。',
    icon: `<path d="M8 4h8v4h4v8h-4v4H8v-4H4V8h4V4Z"/><path d="M9 9h6v6H9z"/>`,
    accent: 'from-blue-500/20 to-indigo-500/5 text-blue-300',
  },
  {
    label: 'EXTENSIONS',
    title: '扩展管理',
    desc: '集中安装、导入、启停扩展，并设置实例级启用范围。',
    icon: `<path d="m12 3 8 4.5v9L12 21l-8-4.5v-9L12 3Z"/><path d="m4 7.5 8 4.5 8-4.5M12 12v9"/>`,
    accent: 'from-violet-500/20 to-fuchsia-500/5 text-violet-300',
  },
  {
    label: 'PORTABILITY',
    title: '实例迁移',
    desc: '完整打包用户数据，跨设备导入后继续使用原有环境。',
    icon: `<path d="M8 7h12m0 0-4-4m4 4-4 4M16 17H4m0 0 4 4m-4-4 4-4"/>`,
    accent: 'from-emerald-500/20 to-cyan-500/5 text-emerald-300',
  },
  {
    label: 'AUTOMATION',
    title: 'Launch API',
    desc: '通过本地 HTTP 接口按 Code、名称或标签调用浏览器实例。',
    icon: `<path d="M13 2 4 14h7l-1 8 10-13h-7V2Z"/>`,
    accent: 'from-amber-500/20 to-orange-500/5 text-amber-300',
  },
]
---

<section id="features" class="relative flex min-h-[calc(100svh-5rem)] scroll-mt-20 items-center border-y border-white/[0.06] bg-[#0a0d17]/65 py-8">
  <div class="pointer-events-none absolute inset-x-0 top-0 mx-auto h-72 max-w-5xl bg-indigo-500/[0.06] blur-[120px]"></div>
  <div class="relative mx-auto w-full max-w-7xl px-6">
    <div class="mb-12 grid gap-6 lg:grid-cols-[1fr_.75fr] lg:items-end">
      <div>
        <p class="mb-4 text-xs font-semibold tracking-[0.22em] text-indigo-300">CORE CAPABILITIES</p>
        <h2 class="max-w-2xl text-3xl font-bold tracking-[-0.035em] text-white sm:text-5xl">
          复杂的环境管理，<br class="hidden sm:block" />变成清晰的日常工作流
        </h2>
      </div>
      <p class="max-w-xl text-sm leading-7 text-muted lg:justify-self-end lg:text-base">
        不需要在多个工具之间来回切换。Facade 将账号环境运行所需的一切放在同一个桌面工作台中。
      </p>
    </div>

    <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-4">
      {features.map((feature) => (
        <article class:list={[
          'group relative min-h-[230px] overflow-hidden rounded-2xl border border-white/[0.08] bg-[#0e1320] p-6 transition duration-300 hover:-translate-y-1 hover:border-white/[0.16] hover:bg-[#111725]',
          feature.wide && 'lg:col-span-2',
        ]}>
          <div class:list={['mb-10 flex h-11 w-11 items-center justify-center rounded-xl bg-gradient-to-br', feature.accent]}>
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" set:html={feature.icon} />
          </div>
          <p class="mb-2 text-[9px] font-semibold tracking-[0.18em] text-[#616c83]">{feature.label}</p>
          <h3 class="text-lg font-semibold text-white">{feature.title}</h3>
          <p class:list={['mt-3 text-sm leading-6 text-muted', feature.wide && 'max-w-lg']}>{feature.desc}</p>
          <div class="pointer-events-none absolute -bottom-16 -right-16 h-40 w-40 rounded-full bg-gradient-to-br from-white/[0.035] to-transparent blur-2xl transition group-hover:from-indigo-400/[0.08]"></div>
        </article>
      ))}
    </div>
  </div>
</section>

<section id="workflow" class="relative flex min-h-[calc(100svh-5rem)] scroll-mt-20 items-center py-8">
  <div class="mx-auto w-full max-w-7xl px-6">
    <div class="mx-auto mb-14 max-w-2xl text-center">
      <p class="mb-4 text-xs font-semibold tracking-[0.22em] text-cyan-300/80">SIMPLE BY DESIGN</p>
      <h2 class="text-3xl font-bold tracking-[-0.035em] text-white sm:text-5xl">三步进入独立工作空间</h2>
      <p class="mt-5 text-sm leading-7 text-muted sm:text-base">从创建到启动，关键信息始终可见，流程无需猜测。</p>
    </div>

    <div class="relative grid gap-4 md:grid-cols-3">
      <div class="pointer-events-none absolute left-[17%] right-[17%] top-10 hidden h-px bg-gradient-to-r from-transparent via-indigo-400/30 to-transparent md:block"></div>
      {[
        ['01', '创建实例', '填写名称与标签，选择需要的 Chromium 内核版本。'],
        ['02', '绑定代理', '从代理池选择出口，检测连通性并保存到实例。'],
        ['03', '一键启动', 'Facade 自动加载隔离数据、扩展和网络配置。'],
      ].map((step) => (
        <div class="relative rounded-2xl border border-white/[0.08] bg-white/[0.025] p-6 md:p-7">
          <span class="relative z-10 mb-8 flex h-12 w-12 items-center justify-center rounded-2xl border border-indigo-400/20 bg-[#111629] font-mono text-xs font-semibold text-indigo-300 shadow-[0_0_30px_rgba(99,102,241,.10)]">{step[0]}</span>
          <h3 class="text-lg font-semibold text-white">{step[1]}</h3>
          <p class="mt-3 text-sm leading-6 text-muted">{step[2]}</p>
        </div>
      ))}
    </div>
  </div>
</section>
